{
  "name": "walrus-nft-media-vault",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "serve out",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "move:build": "cd move && sui move build",
    "move:publish:testnet": "cd move && sui client publish --gas-budget 100000000 --json",
    "deploy:walrus": "npm run build && site-builder deploy ./out --epochs 3",
    "deploy:walrus:update": "npm run build && site-builder update ./out --epochs 3",
    "verify": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@mysten/dapp-kit": "1.0.6",
    "@mysten/sui": "2.17.0",
    "@mysten/walrus": "1.1.7",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-progress": "1.1.7",
    "@radix-ui/react-slot": "1.2.4",
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "8.18.0",
    "@tanstack/react-query": "5.90.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "confetti-react": "2.6.0",
    "framer-motion": "12.23.24",
    "lucide-react": "0.468.0",
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "14.3.8",
    "react-player": "2.16.1",
    "sonner": "1.7.4",
    "serve": "14.2.6",
    "tailwind-merge": "2.6.0",
    "tailwindcss-animate": "1.0.7",
    "three": "0.181.2"
  },
  "devDependencies": {
    "@types/node": "22.15.29",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@types/three": "0.181.0",
    "autoprefixer": "10.4.22",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.18",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.18",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
